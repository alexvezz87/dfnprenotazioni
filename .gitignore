# ==========================================
# Theme GitIgnore - Custom Theme Repository
# ==========================================

# Composer Dependencies (if any)
/vendor/
composer.lock

# IDE & Editor Settings
.vscode/
.idea/
.agents/
*.swp
*.swo
sftp.json
sftp-config.json

# OS Specific Files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Theme specific ignore rules
# (uncomment if you use Node/Build processes in theme)
# node_modules/
# dist/

# Logs & backups
*.log
error_log
functions_backup.php
